{
    "semi": true,
    "singleQuote": true,
    "tabWidth": 4,
    "useTabs": false,
    "printWidth": 100,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf",
    "overrides": [
        {
            "files": ["*.md"],
            "options": {
                "tabWidth": 2,
                "proseWrap": "preserve"
            }
        },
        {
            "files": ["*.njk", "*.html"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
